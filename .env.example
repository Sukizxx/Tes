# ─────────────────────────────────────────────────────────────
# NeiroAI environment variables
# Copy to `.env.local` for local dev, or set these in the Vercel
# dashboard (Project → Settings → Environment Variables) for prod.
# All keys are read SERVER-SIDE ONLY and never exposed to the browser.
# ─────────────────────────────────────────────────────────────

# NVIDIA NIM — powers Nemotron-3 Ultra (coding + judge + reasoning)
# and Nemotron-3 Nano Omni (vision/OCR/multimodal).
# Get a free key at https://build.nvidia.com (format: nvapi-...)
NVIDIA_API_KEY=

# OpenRouter — powers GPT-OSS 120B (support model).
# Get a key at https://openrouter.ai/keys (format: sk-or-...)
OPENROUTER_API_KEY=

# Optional: override the base URLs (defaults are correct for prod).
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: Synox tool layer base (image gen/edit, downloader). No key needed.
# SYNOX_BASE_URL=https://api.synoxcloud.xyz
